# Airtable
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_base_id
AIRTABLE_CANDIDATES_TABLE_ID=your_candidates_table_id
AIRTABLE_EMPLOYERS_TABLE_ID=your_employers_table_id

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Cloudflare R2 (Video Storage)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://pub-your_account_id.r2.dev

# AWS (for Remotion Lambda)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# Remotion Lambda
REMOTION_AWS_REGION=us-east-1
REMOTION_FUNCTION_NAME=your_remotion_function_name
REMOTION_SERVE_URL=your_remotion_serve_url

# Short.io (URL Shortener)
SHORT_IO_API_KEY=your_short_io_api_key
SHORT_DOMAIN=freeworldjobs.short.gy

# HubSpot
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token

# FMCSA SAFER API (Motor Carrier Safety Data)
FMCSA_WEBKEY=your_fmcsa_webkey
