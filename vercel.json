{
  "framework": "vite",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/portfolio/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/record/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/form/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    }
  ]
}
